# Servidor
NODE_ENV=production
PORT=3004
SESSION_SECRET=CAMBIA_ESTE_VALOR_POR_UNO_LARGO_Y_ALEATORIO
TRUST_PROXY=true
SESSION_COOKIE_SECURE=auto
SESSION_COOKIE_NAME=wintrade.sid
SESSION_STORE_TABLE=user_sessions

# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_USER=cyber_admin
DB_PASSWORD=CAMBIA_ESTA_PASSWORD
DB_NAME=cybersolution

# Gemini
GEMINI_API_KEY=CAMBIA_ESTA_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# Bot Futuros base
PAR=BTC-USDT
TIMEFRAME=15m
APALANCAMIENTO=10
RIESGO_POR_TRADE=2
MODO_REAL=true

# Risk management base
PERDIDA_MAXIMA_DIARIA=10
CONFIANZA_MINIMA=0.60

# Futuros hardening
FUTURES_COOLDOWN_AFTER_LOSS_MIN=20
FUTURES_ALLOW_ADD_POSITION=false
FUTURES_MAX_RISK_PCT=3
FUTURES_MIN_SL_DISTANCE_PCT=0.25
FUTURES_MAX_POSITION_UTILIZATION=0.9
FUTURES_CLAMP_POSITION_SIZE=true

# Spot base
CAPITAL_MAXIMO_PCT=80
MODO_REAL_SPOT=true
CONFIANZA_MINIMA_SPOT=0.60

# Spot guardrails
SPOT_MIN_USDT_TO_BUY=10
SPOT_MIN_DROP_PCT_FOR_REBUY=1.5
SPOT_MAX_BUY_RSI_1H=68
SPOT_MAX_BUY_RSI_15M=72
SPOT_MIN_PROFIT_PCT_FOR_SELL=1.0
SPOT_MAX_ACCEPTED_LOSS_PCT=2.5
SPOT_MIN_QTY=0.00001
SPOT_MIN_NOTIONAL_USDT=1

# Spot take-profit escalonado
SPOT_TP_TIER1_PCT=2
SPOT_TP_TIER2_PCT=4
SPOT_TP_TIER3_PCT=6
SPOT_TP_SELL_TIER1=35
SPOT_TP_SELL_TIER2=60
SPOT_TP_SELL_TIER3=100
